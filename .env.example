# Copy this file to ".env" for local testing.
# On Railway/Wispbyte/etc., set these same keys in the host's Environment Variables
# panel instead of uploading a .env file.

# Required: from Discord Developer Portal > Your App > Bot > Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# Required: from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional settings (defaults shown)
COMMAND_PREFIX=!
AI_MODEL=claude-sonnet-4-6
AI_SYSTEM_PROMPT=You are a helpful, friendly Discord server assistant. Keep replies concise and casual.
AI_MAX_HISTORY_TURNS=10
AI_USER_COOLDOWN_SECONDS=5

# Comma-separated channel IDs where the bot replies to every message (not just @mentions)
# Right-click a channel > Copy Channel ID (enable Developer Mode in Discord settings first)
AI_CHANNEL_IDS=

# Comma-separated Discord user IDs of the bot's HOST/OWNER (you). These IDs bypass every
# permission check and every Anti-Nuke punishment, in every server the bot is in.
# Keep this list short and only include accounts you fully trust.
BOT_OWNER_IDS=

# Optional: where per-guild config/warnings/antinuke data is stored (JSON files).
# Make sure this path survives redeploys (Railway volume, etc.) or configs reset.
DATA_DIR=data
